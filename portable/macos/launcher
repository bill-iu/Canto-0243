#!/bin/bash
# macOS .app entry — bundled venv, no system Python required.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
APP_BUNDLE="$(cd "$SCRIPT_DIR/.." && pwd)"
APP_ROOT="$(cd "$SCRIPT_DIR/../Resources/app" && pwd)"

# 下載隔離：系統 Python 清 .app／bundle（Gatekeeper 放行後首次啟動）
if PY3="$(command -v python3 2>/dev/null)"; then
  "$PY3" "$APP_ROOT/scripts/portable_macos.py" "$APP_BUNDLE" "$APP_ROOT" 2>/dev/null || true
elif [[ "$(uname -s)" == "Darwin" ]] && command -v xattr >/dev/null 2>&1; then
  xattr -dr com.apple.quarantine "$APP_BUNDLE" 2>/dev/null || true
  xattr -dr com.apple.quarantine "$APP_ROOT" 2>/dev/null || true
fi

cd "$APP_ROOT"

PY="$APP_ROOT/venv/bin/python"
if [[ ! -x "$PY" ]]; then
  osascript -e 'display alert "Canto-0243" message "找不到內建執行環境。請重新下載完整安裝包。" as critical' || true
  exit 1
fi

if [[ ! -f "$APP_ROOT/lyrics.db" ]]; then
  osascript -e 'display alert "Canto-0243" message "找不到 lyrics.db。請確認已完整解壓。" as critical' || true
  exit 1
fi

export PORTABLE=1
export ENV=local
[[ -f "$APP_ROOT/.env.local" ]] || cp -f "$APP_ROOT/env.portable" "$APP_ROOT/.env.local"

export HOST="${HOST:-127.0.0.1}"
export PORT="${PORT:-8000}"

exec "$PY" "$APP_ROOT/scripts/local_launch.py" \
  --portable --lang zh --wait-server \
  --python "$PY" --root "$APP_ROOT"
