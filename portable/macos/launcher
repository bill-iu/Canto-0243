#!/bin/bash
# macOS .app entry — bundled venv, no system Python required.
set -euo pipefail

APP_ROOT="$(cd "$(dirname "$0")/../Resources/app" && pwd)"
cd "$APP_ROOT"

PY="$APP_ROOT/venv/bin/python"
if [[ ! -x "$PY" ]]; then
  osascript -e 'display alert "Canto-0243" message "找不到內建執行環境。請重新下載完整安裝包。" as critical' || true
  exit 1
fi

if [[ ! -f "$APP_ROOT/lyrics.db" ]]; then
  osascript -e 'display alert "Canto-0243" message "找不到 lyrics.db。請確認已完整解壓。" as critical' || true
  exit 1
fi

export PORTABLE=1
export ENV=local
[[ -f "$APP_ROOT/.env.local" ]] || cp -f "$APP_ROOT/env.portable" "$APP_ROOT/.env.local"

export HOST="${HOST:-127.0.0.1}"
export PORT="${PORT:-8000}"

exec "$PY" "$APP_ROOT/scripts/local_launch.py" \
  --portable --lang zh --wait-server \
  --python "$PY" --root "$APP_ROOT"
