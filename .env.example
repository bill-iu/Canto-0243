# Canto-0243 — 環境變數範例（無 secret，可 commit）
# 使用：複製本檔為 .env.local（connection.py 預設載入 .env.local）

# --- 資料庫（產品保證路徑：SQLite）---
# DATABASE_URL=sqlite:///./lyrics.db

# PostgreSQL（凍結 scaffold：無測試、非產品承諾）
# 需：pip install -r requirements-postgres.txt
# DATABASE_URL=postgresql://postgres:密碼@主機:5432/資料庫名

# --- 執行環境 ---
# local → 載入 .env.local；prod → 載入 .env.prod
# ENV=local

# --- HTTP 伺服器（省略則用預設）---
# HOST=127.0.0.1
# PORT=8000
